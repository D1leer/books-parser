import requests
import csv
import os
from bs4 import BeautifulSoup

with open('qnotes.csv', 'w', newline='', encoding='utf-8') as f:
    writer = csv.writer(f)
    writer.writerow(['название', 'наличие', 'цена'])

    url = 'http://books.toscrape.com/catalogue/page-1.html'
    response = requests.get(url)

    if response.status_code == 200:
        content = response.content.decode('windows-1252')
        soup = BeautifulSoup(content, 'html.parser')
        books = soup.find_all('article', class_='product_pod')
  
        for book in books:
          title = book.find('h3').find('a')['title']
          availability = book.find('p', class_='instock availability').text.strip()
          prise = book.find('p', class_='price_color').text
          prise = prise.replace('Â', ' ')
          print(title)
          print(availability)
          print(prise)

          writer.writerow([title, availability, prise])
    else:
        print('ошибка загрузки сайта')

print('end')
print(os.getcwd())
